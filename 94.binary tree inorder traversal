class Solution:
    def inorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        
        result = []

        def inorder(node):
            if not node:
                return

            inorder(node.left)        # 1. Traverse left subtree
            result.append(node.val)   # 2. Visit current node
            inorder(node.right)       # 3. Traverse right subtree

        inorder(root)
        return result
